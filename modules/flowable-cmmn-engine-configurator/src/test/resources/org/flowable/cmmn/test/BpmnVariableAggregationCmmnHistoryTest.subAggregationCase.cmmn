<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/CMMN/20151109/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/cmmn"
             targetNamespace="http://flowable.org/cmmn">
    <case id="subAggregationCase">
        <casePlanModel id="subCasePlanModel" name="Sub aggregation case">
            <planItem id="planItemReview" name="Review" definitionRef="reviewTask">
                <itemControl>
                    <repetitionRule flowable:ignoreCounterVariable="true">
                        <extensionElements>
                            <flowable:variableAggregation target="reviews">
                                <variable source="approved" target="approved" />
                                <variable source="description" target="description" />
                            </flowable:variableAggregation>
                        </extensionElements>
                        <condition><![CDATA[${repetitionCounter < 3}]]></condition>
                    </repetitionRule>
                </itemControl>
            </planItem>
            <humanTask id="reviewTask" name="Review" />
        </casePlanModel>
    </case>
</definitions>
