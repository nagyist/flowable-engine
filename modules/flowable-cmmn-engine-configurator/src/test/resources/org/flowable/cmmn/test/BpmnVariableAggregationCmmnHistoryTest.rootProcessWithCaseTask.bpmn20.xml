<?xml version="1.0" encoding="UTF-8"?>
<definitions id="definition"
             xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             targetNamespace="Examples">

    <process id="rootProcessWithCaseTask" isExecutable="true">
        <startEvent id="theStart" />
        <sequenceFlow id="flow1" sourceRef="theStart" targetRef="caseTask" />
        <serviceTask id="caseTask" flowable:type="case" flowable:caseDefinitionKey="subAggregationCase" />
        <sequenceFlow id="flow2" sourceRef="caseTask" targetRef="theEnd" />
        <endEvent id="theEnd" />
    </process>

</definitions>
